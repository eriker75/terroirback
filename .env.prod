# =============================================================
# TERROIR - Entorno de producción
# Usado en: docker-compose.prod.yml y Cloud Run
# =============================================================

# ---------------------------------------------------------------
# PostgreSQL
# Para VPS/local-prod: postgres corre en el mismo compose
# Para Cloud Run: usa Cloud SQL — establece DATABASE_URL directamente
# ---------------------------------------------------------------
POSTGRES_USER=terroir_user
POSTGRES_PASSWORD=CAMBIA_ESTO_CON_CLAVE_FUERTE
POSTGRES_DB=terroir_db
POSTGRES_EXT_PORT=5432
TZ=America/Caracas

# DATABASE_URL directa (tiene prioridad sobre las vars individuales)
# Cloud Run + Cloud SQL (Unix socket):
#   DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# VPS / local-prod (TCP):
DATABASE_URL=postgresql://terroir_user:CAMBIA_ESTO_CON_CLAVE_FUERTE@postgres:5432/terroir_db?schema=public

# ---------------------------------------------------------------
# Backend
# ---------------------------------------------------------------
PORT=3000
BACKEND_PORT=3000

# Node image para el build (opcional)
NODE_IMAGE=node:20-alpine

# ---------------------------------------------------------------
# JWT — generar con: openssl rand -base64 64
# ---------------------------------------------------------------
JWT_SECRET=GENERA_UN_SECRET_FUERTE_AQUI

# ---------------------------------------------------------------
# SMTP real (producción)
# Opciones: SendGrid, Brevo, Resend, Gmail App Password, etc.
# ---------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-gmail
SMTP_FROM=noreply@terroir.com

# ---------------------------------------------------------------
# AWS S3 (almacenamiento de imágenes/archivos)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=terroir-uploads-prod

# ---------------------------------------------------------------
# Stripe (claves de producción LIVE)
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------
# GCP / Cloud Run (referencia para despliegue)
# ---------------------------------------------------------------
# GCP_PROJECT_ID=tu-gcp-project-id
# GCP_REGION=us-central1
# CLOUD_SQL_INSTANCE=tu-proyecto:us-central1:terroir-db
