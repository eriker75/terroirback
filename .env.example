# =============================================================
# TERROIR - Variables de entorno (copia este archivo a .env y completa los valores)
# =============================================================

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
POSTGRES_USER=terroir_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=terroir_db
POSTGRES_EXT_PORT=5432
TZ=America/Caracas

# DATABASE_URL: construida automáticamente por docker-compose.dev.yml
# a partir de las vars anteriores. Si quieres sobreescribirla:
# DATABASE_URL=postgresql://terroir_user:change_me@postgres:5432/terroir_db?schema=public

# ---------------------------------------------------------------
# Backend
# ---------------------------------------------------------------
PORT=3000
BACKEND_PORT=3000

# ---------------------------------------------------------------
# CORS — orígenes permitidos (separados por coma)
# En producción reemplaza con la URL real del frontend
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:7050

# ---------------------------------------------------------------
# JWT — usar un secreto largo y aleatorio en producción
# ---------------------------------------------------------------
JWT_SECRET=change_me_use_a_long_random_secret

# ---------------------------------------------------------------
# pgAdmin (interfaz web para la DB)  → http://localhost:5050
# ---------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@terroir.com
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# ---------------------------------------------------------------
# Mailpit (SMTP local + UI)
# SMTP UI → http://localhost:8025
# ---------------------------------------------------------------
MAILPIT_SMTP_USER=mailpit
MAILPIT_SMTP_PASS=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Variables de SMTP que usa la app (apuntan a mailpit en dev)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_FROM=noreply@terroir.local

# ---------------------------------------------------------------
# AWS S3 (almacenamiento de imágenes/archivos)
# Dejar vacío en dev para usar almacenamiento local (uploads/)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
