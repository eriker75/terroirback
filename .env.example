# =============================================================
# TERROIR - Variables de entorno (copia este archivo a .env y completa los valores)
# =============================================================

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
POSTGRES_USER=terroir_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=terroir_db
POSTGRES_EXT_PORT=5432
TZ=America/Caracas

# DATABASE_URL: construida automáticamente por docker-compose.dev.yml
# a partir de las vars anteriores. Si quieres sobreescribirla:
# DATABASE_URL=postgresql://terroir_user:change_me@postgres:5432/terroir_db?schema=public
#
# NOTA (PostGIS): el envío guarda la ubicación en una columna geográfica
# (addresses.location). El Postgres debe tener la extensión `postgis`
# habilitada (usa la imagen postgis/postgis, o ejecuta
# `CREATE EXTENSION IF NOT EXISTS postgis;`) ANTES de correr las migraciones.
# Ver sql/bcv_postgis.sql.

# ---------------------------------------------------------------
# Backend
# ---------------------------------------------------------------
PORT=3000
BACKEND_PORT=3000

# ---------------------------------------------------------------
# CORS — orígenes permitidos (separados por coma)
# En producción reemplaza con la URL real del frontend
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:7050

# ---------------------------------------------------------------
# JWT — usar un secreto largo y aleatorio en producción
# ---------------------------------------------------------------
JWT_SECRET=change_me_use_a_long_random_secret

# ---------------------------------------------------------------
# pgAdmin (interfaz web para la DB)  → http://localhost:5050
# ---------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@terroir.com
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# ---------------------------------------------------------------
# Mailpit (SMTP local + UI)
# SMTP UI → http://localhost:8025
# ---------------------------------------------------------------
MAILPIT_SMTP_USER=mailpit
MAILPIT_SMTP_PASS=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Variables de SMTP que usa la app (apuntan a mailpit en dev)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_FROM=noreply@terroir.local

# ---------------------------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS
# Backend de storage: 'local' (disco, carpeta uploads/), 's3' (AWS/compatible)
# o 'gcs' (Google Cloud Storage). En dev usar 'local'.
# ---------------------------------------------------------------
STORAGE_TYPE=local

# Carpeta raíz local (opcional; por defecto <cwd>/uploads)
# UPLOAD_ROOT=
# URL pública del backend para construir URLs de archivos locales
# BACKEND_PUBLIC_URL=http://localhost:3000

# --- AWS S3 (o compatible: DigitalOcean Spaces, MinIO) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Acepta AWS_S3_BUCKET o AWS_S3_BUCKET_NAME
AWS_S3_BUCKET=
# AWS_S3_BUCKET_NAME=
# Para S3 compatible (Spaces/MinIO): endpoint y path-style
# AWS_S3_ENDPOINT=
# AWS_S3_FORCE_PATH_STYLE=false

# --- Google Cloud Storage (activar con STORAGE_TYPE=gcs) ---
# Pasos en https://console.cloud.google.com :
#
# 1) PROYECTO: copia el "ID del proyecto" (Dashboard, no el nombre)
#    → GCP_PROJECT_ID         Ej: terroir-coffee-470912
#
# 2) BUCKET: Cloud Storage → Buckets → Crear → copia el nombre del bucket
#    → GCS_BUCKET_NAME        Ej: terroir-uploads
#    Para que las URLs públicas funcionen, en el bucket:
#      Permissions → Grant access → New principal: allUsers
#      → rol "Storage Object Viewer"  (con Uniform bucket-level access activado)
#
# 3) CREDENCIALES (cuenta de servicio):
#    IAM & Admin → Service Accounts → Crear cuenta de servicio
#      → rol "Storage Object Admin"
#      → en la cuenta: Keys → Add key → Create new key → JSON → Descargar
#    Usa UNA de estas dos opciones con ese .json:
#
#    OPCIÓN A (recomendada en Docker) — montar el archivo:
#      a. Guarda el .json en  backend/secrets/gcs-key.json
#      b. En docker-compose.dev.yml (backend → volumes) agrega:
#             - ./secrets:/usr/src/app/secrets:ro
#      c. GOOGLE_APPLICATION_CREDENTIALS=/usr/src/app/secrets/gcs-key.json
#
#    OPCIÓN B (sin montar nada) — pegar el JSON completo en UNA línea,
#    entre comillas SIMPLES (no dobles, para no romper los \n del private_key):
#      GCS_CREDENTIALS_JSON='{"type":"service_account","project_id":"...",...}'
GCS_BUCKET_NAME=
GCP_PROJECT_ID=terroir-497922
# Opción A: ruta al archivo de credenciales montado
GOOGLE_APPLICATION_CREDENTIALS=
# Opción B: el JSON completo en una línea entre comillas simples
# GCS_CREDENTIALS_JSON=
# Alias de GOOGLE_APPLICATION_CREDENTIALS (ruta a archivo)
# GCS_KEY_FILE=
# CDN/base pública opcional (por defecto https://storage.googleapis.com/<bucket>)
# GCS_PUBLIC_BASE_URL=

# ---------------------------------------------------------------
# PAGOS — Webhook de R4 (pago móvil)
# ---------------------------------------------------------------
# Token (UUID) que R4 envía en el header Authorization de sus webhooks
# (POST /api/webhooks/r4/notifica y /api/webhooks/r4/consulta). Debe coincidir
# con el configurado en el panel de R4. OBLIGATORIO: el webhook es BLOQUEANTE —
# si el token falta o no coincide responde 401 y NO confirma el pago (evita
# confirmaciones forjadas de órdenes).
R4_WEBHOOK_TOKEN=

# Integración R4 SALIENTE (FUTURO — aún no usada por el código; descomenta al
# implementar consultas/cobros directos contra R4):
# R4_BASE_URL=https://r4conecta.mibanco.com.ve
# R4_COMMERCE_ID=
# R4_CUENTA_BANCO=
# R4_CUENTA_CEDULA=
# R4_CUENTA_TELEFONO=

# ---------------------------------------------------------------
# TASA BCV (USD→VES)
# ---------------------------------------------------------------
# No requiere variables: la tasa se obtiene de un API público gratuito
# (open.er-api.com, sin API key), se guarda en la tabla `bcv_rates` y puede
# fijarse manualmente desde el dashboard (admin).

# ---------------------------------------------------------------
# NOTIFICACIONES PUSH (Expo)
# ---------------------------------------------------------------
# OPCIONAL. Access token de Expo (Expo Access Tokens en expo.dev → Account
# Settings). Sin él las push funcionan igual; el token sólo eleva los límites de
# rate de la API de Expo y permite envíos autenticados. Si está vacío, el SDK
# (expo-server-sdk) envía sin autenticación (suficiente para volúmenes normales).
EXPO_ACCESS_TOKEN=

# ---------------------------------------------------------------
# LOGIN CON GOOGLE (id_token)
# ---------------------------------------------------------------
# Client IDs OAuth de Google Cloud Console (APIs & Services → Credentials).
# El backend NO necesita el client secret: sólo verifica la firma del id_token y
# que su `aud` sea uno de estos IDs. Define el de cada plataforma que uses:
#   · WEB     → "OAuth client" tipo Web application (lo usa la web GIS y también
#               es el `webClientId` del SDK nativo en móvil para emitir id_token).
#   · IOS     → "OAuth client" tipo iOS (bundle com.terroir.eribert).
#   · ANDROID → "OAuth client" tipo Android (package com.terroir.somosnodo + SHA-1).
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# ---------------------------------------------------------------
# LOGIN CON APPLE (identity_token)
# ---------------------------------------------------------------
# El backend verifica la firma del identity_token contra las llaves de Apple y
# que su `aud` sea uno de estos. NO necesita secretos:
#   · BUNDLE ID  → app iOS nativa (expo-apple-authentication). Igual al
#                  ios.bundleIdentifier del app.json: com.terroir.eribert.
#   · SERVICE ID → "Services ID" del portal de Apple, usado por la WEB
#                  (Sign in with Apple JS). Ej: com.terroir.web.signin
APPLE_BUNDLE_ID=
APPLE_SERVICE_ID=
