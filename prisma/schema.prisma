// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ProductRelationType {
  UPSELL
  CROSS_SELL
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum NotificationAudience {
  ALL_USERS
  NEW_USERS
  VIP
  INACTIVE
  CART_ABANDONMENT
  NEWSLETTER
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
  TRASHED
}

enum ContactBlockType {
  EMAIL
  IP
  KEYWORD
}

// -----------------------------------------------------------------------------
// USUARIOS
// -----------------------------------------------------------------------------
// userId  → PK autoincremental (interno / base de datos)
// id      → UUID único (externo / API / URLs)
// Las FKs entre modelos apuntan a `id` (UUID) para no exponer secuencias.
// -----------------------------------------------------------------------------
model User {
  userId           Int       @id @default(autoincrement())
  id               String    @unique @default(uuid())
  email            String    @unique
  firstName        String
  lastName         String
  avatar           String?
  password         String?   // opcional: las cuentas creadas vía login social (Google/Apple) no tienen contraseña local
  phone            String
  address          String
  city             String
  state            String
  zip              String
  country          String    @default("Venezuela")
  role             String    @default("customer")
  status           String    @default("active")

  orders         Order[]
  wishlist       Wishlist?
  cart           Cart?
  addresses      Address[]
  refreshTokens  RefreshToken[]
  socialAccounts SocialAccount[]
  contacts       Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// -----------------------------------------------------------------------------
// AUTENTICACIÓN SOCIAL (Google, Apple, …)
// -----------------------------------------------------------------------------
// Cada fila vincula la cuenta de un proveedor externo (OIDC/OAuth) con un User
// local. Un mismo User puede tener varias (p.ej. Google y Apple a la vez).
//
// Flujo de login social previsto:
//   1) El cliente obtiene un id_token del proveedor (Google/Apple).
//   2) El backend lo verifica y extrae el provider + el `sub` (= providerAccountId).
//   3) Se busca por (provider, providerAccountId):
//        · existe     → se emite el par de tokens para el User vinculado.
//        · no existe   → se crea el User (sin password) + su SocialAccount,
//                        o se vincula al User existente que ya tenga ese email.
model SocialAccount {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          String    // "google" | "apple" | ...
  providerAccountId String    // id estable del proveedor (claim `sub` del id_token)

  // Snapshot informativo del perfil que devuelve el proveedor
  email             String?
  name              String?
  avatar            String?

  // Tokens del proveedor (opcionales; sólo si más adelante consumimos sus APIs).
  // Si se almacenan, conviene cifrarlos en reposo.
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // No puede vincularse dos veces la misma cuenta del mismo proveedor
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("social_accounts")
}

model Address {
  addressId     Int      @id @default(autoincrement())
  id            String   @unique @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  recipientName String
  phone         String
  line1         String
  line2         String?
  city          String
  state         String
  zip           String
  country       String   @default("Venezuela")
  latitude      Float?
  longitude     Float?
  // PostGIS DESHABILITADO (diferido): requiere la extensión `postgis` en Postgres
  // (imagen postgis/postgis o `CREATE EXTENSION postgis`). Hoy la ubicación se
  // guarda en `latitude`/`longitude` (Float). Para reactivar: habilita postgis,
  // descomenta la línea de abajo y el bloque $executeRaw en orders.service. Prisma
  // NO escribe tipos Unsupported (se puebla con SQL crudo). Ver sql/bcv_postgis.sql.
  // location      Unsupported("geography(Point, 4326)")?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shippingOrders Order[] @relation("OrderShippingAddress")

  @@map("addresses")
}

// -----------------------------------------------------------------------------
// CATÁLOGO E INVENTARIO
// -----------------------------------------------------------------------------
model Category {
  categoryId Int        @id @default(autoincrement())
  id         String     @unique @default(uuid())
  name       String
  slug       String     @unique
  image      String?
  parentId   String?
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]  @relation("CategoryProducts")

  @@map("categories")
}

model Product {
  productId    Int     @id @default(autoincrement())
  id           String  @unique @default(uuid())
  name         String
  description  String
  price        Decimal
  mainImage    String?
  images       Json
  stock        Int     @default(0)
  pointsPrice  Float?
  pointsEarned Float?

  categoryId String?
  category   Category? @relation("CategoryProducts", fields: [categoryId], references: [id])

  variants           ProductVariant[]
  attributes         ProductAttribute[]
  productTags        ProductTag[]
  couponProducts     CouponProduct[]

  relatedProducts ProductRelated[] @relation("relatedProducts")
  relatedTo       ProductRelated[] @relation("relatedTo")

  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@map("product_variants")
}

model ProductAttribute {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@index([productId])
  @@unique([productId, name])
  @@map("product_attributes")
}

model Tag {
  tagId       Int          @id @default(autoincrement())
  id          String       @unique @default(uuid())
  name        String       @unique
  slug        String       @unique
  productTags ProductTag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tags")
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
  @@map("product_tags")
}

model ProductRelated {
  id           String              @id @default(uuid())
  productId    String
  product      Product             @relation("relatedProducts", fields: [productId], references: [id], onDelete: Cascade)
  relatedId    String
  related      Product             @relation("relatedTo", fields: [relatedId], references: [id], onDelete: Cascade)
  relationType ProductRelationType
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([productId, relatedId, relationType])
  @@index([productId])
  @@index([relatedId])
  @@map("product_relations")
}

// -----------------------------------------------------------------------------
// CUPONES Y DESCUENTOS
// -----------------------------------------------------------------------------
model Coupon {
  couponId     Int          @id @default(autoincrement())
  id           String       @unique @default(uuid())
  code         String       @unique
  discountType DiscountType
  amount       Decimal
  isActive     Boolean      @default(true)
  expiryDate   DateTime?
  usageLimit   Int?
  usageCount   Int          @default(0)

  carts            Cart[]
  orders           Order[]
  couponProducts   CouponProduct[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

model CouponProduct {
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([productId])
  @@map("coupon_products")
}

// -----------------------------------------------------------------------------
// CARRITO DE COMPRAS
// -----------------------------------------------------------------------------
model Cart {
  cartId Int    @id @default(autoincrement())
  id     String @unique @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@map("cart_items")
}


// -----------------------------------------------------------------------------
// WISHLIST
// -----------------------------------------------------------------------------
model Wishlist {
  wishlistId Int            @id @default(autoincrement())
  id         String         @unique @default(uuid())
  userId     String         @unique
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

// -----------------------------------------------------------------------------
// PEDIDOS Y PAGOS
// -----------------------------------------------------------------------------
model Order {
  orderId         Int         @id @default(autoincrement())
  id              String      @unique @default(uuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id])

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  shippingAddressId String?
  shippingAddress   Address?  @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  contactId         String?
  contact           Contact?  @relation(fields: [contactId], references: [id])
  payment           Payment?
  shipping          Decimal   @default(0)
  notes             String?

  discount Decimal     @default(0)
  total    Decimal
  status   OrderStatus @default(PENDING)

  items     OrderItem[]
  createdAt DateTime    @default(now())

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal

  @@map("order_items")
}

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  orders    Order[]
  messages  ContactMessage[]
  blocks    ContactBlock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("contacts")
}

model Payment {
  id              String    @id @default(uuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          String    // 'pago_movil' | 'efectivo' | 'puntos' | 'yummy'
  status          String    @default("PENDING") // PENDING|PROCESSING|COMPLETED|FAILED|REFUNDED
  amount          Decimal
  currency        String    @default("USD")
  reference       String?
  payerIdDocument String?
  payerName       String?
  payerPhone      String?
  bank            String?
  bcvRate         Decimal?
  amountVes       Decimal?
  rawWebhook      Json?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([reference])
  @@map("payments")
}

// -----------------------------------------------------------------------------
// BANNERS Y PROMOCIONES
// -----------------------------------------------------------------------------
model Banner {
  bannerId    Int      @id @default(autoincrement())
  id          String   @unique @default(uuid())
  image       String
  title       String
  description String
  buttonText  String
  buttonLink  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

// -----------------------------------------------------------------------------
// CONFIGURACIÓN GLOBAL DEL SITIO
// -----------------------------------------------------------------------------
model Setting {
  settingId Int      @id @default(autoincrement())
  id        String   @unique @default(uuid())
  metaKey   String   @unique
  metaValue String
  metaGroup String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([metaGroup])
  @@map("settings")
}

// -----------------------------------------------------------------------------
// TASA BCV (USD → VES)
// -----------------------------------------------------------------------------
// Historial de tasas. La fila más reciente (createdAt desc) es la tasa vigente.
model BcvRate {
  id        String   @id @default(uuid())
  rate      Decimal  @db.Decimal(18, 4)
  source    String   // 'EXCHANGERATE_API' | 'MANUAL' | 'R4'
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("bcv_rates")
}

// -----------------------------------------------------------------------------
// NOTIFICACIONES
// -----------------------------------------------------------------------------
model Notification {
  id          String               @id @default(uuid())
  title       String
  message     String
  audience    NotificationAudience @default(ALL_USERS)
  status      NotificationStatus   @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("notifications")
}

// -----------------------------------------------------------------------------
// MENSAJES DE CONTACTO (formulario público → bandeja del dashboard)
// -----------------------------------------------------------------------------
model ContactMessage {
  id        String               @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  ipAddress String?
  status    ContactMessageStatus @default(NEW)
  contactId String?
  contact   Contact?             @relation(fields: [contactId], references: [id])
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// Lista negra anti-spam: emails, IPs o palabras clave que se rechazan
// automáticamente al recibir un mensaje de contacto.
model ContactBlock {
  id        String           @id @default(uuid())
  type      ContactBlockType
  value     String
  reason    String?
  contactId String?
  contact   Contact?         @relation(fields: [contactId], references: [id])
  createdAt DateTime         @default(now())

  @@unique([type, value])
  @@index([type])
  @@index([contactId])
  @@map("contact_blocks")
}