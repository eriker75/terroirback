// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponApplicationMode {
  CART
  GROUP
  ITEM
}

// -----------------------------------------------------------------------------
// USUARIOS
// -----------------------------------------------------------------------------
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String
  lastName         String
  avatar           String?
  password         String
  phone            String
  address          String
  city             String
  state            String
  zip              String
  country          String    @default("Venezuela")
  role             String    @default("customer")
  status           String    @default("active")
  stripeCustomerId String?   @unique
  
  orders           Order[]
  wishlist         Wishlist?
  cart             Cart?
  addresses        Address[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?
  recipientName String
  phone         String
  line1         String
  line2         String?
  city          String
  state         String
  zip           String
  country       String   @default("Venezuela")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CATÁLOGO E INVENTARIO
// -----------------------------------------------------------------------------
model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]  @relation("CategoryProducts")
}

model Product {
  id            String           @id @default(cuid())
  name          String
  description   String
  price         Decimal
  mainImage     String?
  images        Json
  stock         Int              @default(0)
  
  categoryId    String
  category      Category         @relation("CategoryProducts", fields: [categoryId], references: [id])
  
  variants      ProductVariant[]
  attributes    ProductAttribute[]
  productTags   ProductTag[]
  couponProducts CouponProduct[]
  couponAppliedItems CartCouponAppliedItem[]
  
  upsells       Product[]        @relation("ProductUpsells")
  upsellOf      Product[]        @relation("ProductUpsells")
  crossSells    Product[]        @relation("ProductCrossSells")
  crossSellOf   Product[]        @relation("ProductCrossSells")
  
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String  
  value     String  
}

model ProductAttribute {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@index([productId])
  @@unique([productId, name])
}

model Tag {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  productTags ProductTag[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

// -----------------------------------------------------------------------------
// CUPONES Y DESCUENTOS
// -----------------------------------------------------------------------------
model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  discountType DiscountType
  amount       Decimal
  isActive     Boolean      @default(true)
  expiryDate   DateTime?
  usageLimit   Int?         // Límite total de veces que puede usarse
  usageCount   Int          @default(0)

  carts        Cart[]
  orders       Order[]
  couponProducts     CouponProduct[]
  cartApplications   CartCouponApplication[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model CouponProduct {
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([productId])
}

// -----------------------------------------------------------------------------
// CARRITO DE COMPRAS
// -----------------------------------------------------------------------------
model Cart {
  id       String     @id @default(cuid())
  userId   String     @unique
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  couponId String?
  coupon   Coupon?    @relation(fields: [couponId], references: [id])
  
  items               CartItem[]
  couponApplications  CartCouponApplication[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([cartId, productId])
}

model CartCouponApplication {
  id        String                @id @default(cuid())
  cartId    String
  cart      Cart                  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  couponId  String
  coupon    Coupon                @relation(fields: [couponId], references: [id], onDelete: Cascade)
  mode      CouponApplicationMode
  items     CartCouponAppliedItem[]
  createdAt DateTime              @default(now())

  @@index([cartId])
  @@index([couponId])
}

model CartCouponAppliedItem {
  id            String                @id @default(cuid())
  applicationId String
  application   CartCouponApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  productId     String
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([applicationId, productId])
  @@index([productId])
}

// -----------------------------------------------------------------------------
// WISHLIST
// -----------------------------------------------------------------------------
model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  WishlistItem[] 
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId])
}

// -----------------------------------------------------------------------------
// PEDIDOS Y PAGOS
// -----------------------------------------------------------------------------
model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  stripeSessionId String      @unique 
  
  // Referencia al cupón usado
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  
  discount        Decimal     @default(0) // Monto exacto descontado
  total           Decimal
  status          OrderStatus @default(PENDING)
  
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal
}

// -----------------------------------------------------------------------------
// BANNERS Y PROMOCIONES
// -----------------------------------------------------------------------------
model Banner {
  id          String   @id @default(cuid())
  image       String
  title       String
  description String
  buttonText  String
  buttonLink  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}